ScreenManager:
    HomeScreen:
        name:'home'
    
    AddScreen:
        name:'add'
    
    SettingScreen:
        name: 'setting'


<HomeScreen>:
    MDBoxLayout:
        orientation:'vertical'
        spacing:dp(50)
        
        MDTopAppBar:
            title:'Passwords'
            
        MDScrollView:
            MDList:
                spacing:dp(40)
                id:lstpwd
            
        MDBottomNavigation:
            MDBottomNavigationItem:
                icon:'home'
                
            MDBottomNavigationItem:
                icon:'plus'
                on_tab_press: app.root.current = 'add'
                
            MDBottomNavigationItem:
                icon:'cog'
                on_tab_press: app.root.current = 'setting'

<AddScreen>:
    MDBoxLayout:
        orientation:'vertical'
        spacing:dp(50)

        MDTopAppBar:
            title:'Add new Password'
        
        MDBoxLayout:
            orientation:'vertical'
            spacing:dp(100)
            padding:dp(10), 0, dp(20), 0

            MDBoxLayout:
                size_hint_y:None
                height:100 

                MDLabel:
                    text: 'App Name:'
                    color:'black'
                    padding: dp(50), dp(45), 0, 0
                    font_size:pt(14)
                
                MDTextField:
                    mode:'rectangle'
                    id:appname

            MDBoxLayout:
                MDLabel:
                    text:'Password:'
                    color:'black'
                    font_size:pt(14)
                    padding: dp(50), dp(45), 0, 0
                    size_hint_y:None
                    height:100 
                
                MDTextField:
                    size_hint_y:None 
                    height:100
                    mode:'rectangle'
                    id:apppassword
            
            MDBoxLayout:
                MDLabel:
                    text:'Username'
                    color:'black'
                    font_size:pt(14)
                    padding:dp(50), dp(45), 0, 0
                    size_hint_y:None 
                    height:100
                
                MDTextField:
                    size_hint_y:None 
                    height:100
                    mode:'rectangle'
                    id:appusername
            
            AnchorLayout:
                anchor_x:'center'
                anchor_y:'bottom'

                MDRaisedButton:
                    text:'Add'
                    size_hint_x:0.8
                    on_release: root.adicionar()
        
        MDBottomNavigation:
            size_hint_y:0.4
            

            MDBottomNavigationItem:
                icon:'home'
                on_tab_press: app.root.current = 'home'
                
            MDBottomNavigationItem:
                icon:'plus'
                
            MDBottomNavigationItem:
                icon:'cog'
                on_tab_press: app.root.current = 'setting'

<SettingScreen>:
    MDBoxLayout:
        orientation:'vertical'

        MDTopAppBar:
            title:'Settings'
        
        MDBoxLayout:

        MDBottomNavigation:
            MDBottomNavigationItem:
                icon:'home'
                on_tab_press:app.root.current = 'home'
            
            MDBottomNavigationItem:
                icon:'plus'
                on_tab_press: app.root.current = 'add'
            
            MDBottomNavigationItem:
                icon:'cog'