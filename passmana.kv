ScreenManager:
    HomeScreen:
        name:'home'
    
    AddScreen:
        name:'add'
    
    SettingScreen:
        name: 'setting'


<HomeScreen>:
    MDBoxLayout:
        orientation:'vertical'
        
        MDTopAppBar:
            title:'Passwords'
            
        MDBoxLayout:
            orientation:'vertical'
            id:'boxpasswords'
            
        MDBottomNavigation:
            MDBottomNavigationItem:
                icon:'home'
                
            MDBottomNavigationItem:
                icon:'plus'
                on_tab_press: app.root.current = 'add'
                
            MDBottomNavigationItem:
                icon:'cog'
                on_tab_press: app.root.current = 'setting'

<AddScreen>:
    MDBoxLayout:
        orientation:'vertical'

        MDTopAppBar:
            title:'Add new Password'

        MDBoxLayout:
            size_hint_y:None
            height:100 

            MDLabel:
                text: 'App Name'
                color:'black'
                md_bg_color: 0.2, 0.4, 1, .5 
            
            MDTextField:

        MDBoxLayout:
            MDLabel:
                text:'Password'
                color:'black'
                size_hint_y:None
                height:100 
            
            MDTextField:
                size_hint_y:None 
                height:100

        
        MDRaisedButton:
            text:'Add'
            halign:'center'
            size_hint_x:1
        
        MDBottomNavigation:
            MDBottomNavigationItem:
                icon:'home'
                on_tab_press: app.root.current = 'home'
                
            MDBottomNavigationItem:
                icon:'plus'
                
            MDBottomNavigationItem:
                icon:'cog'
                on_tab_press: app.root.current = 'setting'

<SettingScreen>:
    MDBoxLayout:
        orientation:'vertical'

        MDTopAppBar:
            title:'Settings'
        
        MDBoxLayout:

        MDBottomNavigation:
            MDBottomNavigationItem:
                icon:'home'
                on_tab_press:app.root.current = 'home'
            
            MDBottomNavigationItem:
                icon:'plus'
                on_tab_press: app.root.current = 'add'
            
            MDBottomNavigationItem:
                icon:'cog'