ScreenManager:
    HomeScreen:
        name:'home'
    
    AddScreen:
        name:'add'
    
    SettingScreen:
        name: 'setting'


<HomeScreen>:
    MDBoxLayout:
        orientation:'vertical'
        
        MDTopAppBar:
            title:'Passwords'
            
        MDBoxLayout:
            orientation:'vertical'
            id:'boxpasswords'
            
        MDBottomNavigation:
            MDBottomNavigationItem:
                icon:'home'
                
            MDBottomNavigationItem:
                icon:'plus'
                
            MDBottomNavigationItem:
                icon:'cog'