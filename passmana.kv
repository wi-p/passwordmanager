ScreenManager:
    HomeScreen:
        name:'home'
    
    AddScreen:
        name:'add'
    
    SettingScreen:
        name: 'setting'


<HomeScreen>:
    MDBoxLayout:
        orientation:'vertical'
        spacing:dp(50)
        
        MDTopAppBar:
            title:'Passwords'

        MDBoxLayout:
            size_hint_y:None
            height:dp(20)
            padding:dp(10)
            spacing:dp(10)

            MDLabel:
                text:'ID'
                bold:True
                size_hint_x:None 
                width:dp(40)

            MDLabel:
                text:'App name'
                bold:True
            
            MDLabel:
                text:'Username'
                bold:True
            
            MDLabel:
                text:'Password'
                bold:True
            
            MDLabel:
                text:'Option'
                bold:True

        MDScrollView:
            MDBoxLayout:
                spacing:dp(20)
                size_hint_y:None
                orientation:'vertical'
                height:self.minimum_height
                id:lstpwd
                padding:dp(10)
            
        MDBottomNavigation:
            size_hint_y:0.1

            MDBottomNavigationItem:
                icon:'home'
                
            MDBottomNavigationItem:
                icon:'plus'
                on_tab_press: app.root.current = 'add'
                
            MDBottomNavigationItem:
                icon:'cog'
                on_tab_press: app.root.current = 'setting'

<AddScreen>:
    MDBoxLayout:
        orientation:'vertical'
        spacing:dp(50)

        MDTopAppBar:
            title:'Add new Password'
        
        MDBoxLayout:
            orientation:'vertical'
            spacing:dp(100)
            padding:dp(10), 0, dp(20), 0

            MDBoxLayout:
                size_hint_y:None
                height:100 

                MDLabel:
                    text: 'App Name:'
                    color:'black'
                    padding: dp(50), dp(45), 0, 0
                    font_size:pt(14)
                
                MDTextField:
                    mode:'rectangle'
                    id:appname

            MDBoxLayout:
                MDLabel:
                    text:'Password:'
                    color:'black'
                    font_size:pt(14)
                    padding: dp(50), dp(45), 0, 0
                    size_hint_y:None
                    height:100 
                
                MDTextField:
                    size_hint_y:None 
                    height:100
                    mode:'rectangle'
                    id:apppassword
            
            MDBoxLayout:
                MDLabel:
                    text:'Username'
                    color:'black'
                    font_size:pt(14)
                    padding:dp(50), dp(45), 0, 0
                    size_hint_y:None 
                    height:100
                
                MDTextField:
                    size_hint_y:None 
                    height:100
                    mode:'rectangle'
                    id:appusername
            
            AnchorLayout:
                anchor_x:'center'
                anchor_y:'bottom'

                MDRaisedButton:
                    text:'Add'
                    size_hint_x:0.8
                    on_release: root.adicionar()
        
        MDBottomNavigation:
            size_hint_y:0.4
            

            MDBottomNavigationItem:
                icon:'home'
                on_tab_press: app.root.current = 'home'
                
            MDBottomNavigationItem:
                icon:'plus'
                
            MDBottomNavigationItem:
                icon:'cog'
                on_tab_press: app.root.current = 'setting'

<SettingScreen>:
    MDBoxLayout:
        orientation:'vertical'

        MDTopAppBar:
            title:'Settings'
        
        MDBoxLayout:
            padding:dp(50), 0, dp(10), 0

            MDBoxLayout:
                size_hint_y:None
                height:dp(100)
                
                MDLabel:
                    text:'Theme:'
                
                MDRaisedButton:
                    text: app.theme_cls.theme_style
                    on_release:app.changeTheme()

        MDBottomNavigation:
            MDBottomNavigationItem:
                icon:'home'
                on_tab_press:app.root.current = 'home'
            
            MDBottomNavigationItem:
                icon:'plus'
                on_tab_press: app.root.current = 'add'
            
            MDBottomNavigationItem:
                icon:'cog'